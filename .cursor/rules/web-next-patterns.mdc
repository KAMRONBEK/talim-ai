description: Apply when editing Next.js pages, components, hooks, stores, or shared UI in apps/web or packages/ui
globs: apps/web/**/*.{ts,tsx}, packages/ui/**/*.{ts,tsx}, packages/types/**/*.ts
alwaysApply: false
