# Template for Doppler secrets (import or use `doppler secrets substitute`)
# Run: doppler secrets upload env.template --project talim-ai --config dev

# --- API ---
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://talim:talim@localhost:5432/talim
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-to-a-secret-at-least-32-characters-long
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_THINKING=disabled
OPENAI_API_KEY=
TRANSCRIPTION_MODEL=whisper-1
TTS_MODEL=tts-1-hd
TTS_PROVIDER=openai
ELEVENLABS_API_KEY=
DEFAULT_CONTENT_LOCALE=uz
TUTOR_MODEL=gpt-4o
TUTOR_TEMPERATURE=0.7
# Optional: path to manim CLI for real video renders (falls back to SVG animation if unset)
MANIM_BIN=
UPLOAD_DIR=./uploads
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# --- Web (NEXT_PUBLIC_* exposed to browser) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_DESMOS_API_KEY=

# --- Docker Compose ---
# Use: pnpm docker:up   (runs: doppler run -- docker compose up)
# Do not use plain `docker compose up` unless you have a root .env with JWT_SECRET (32+ chars).
# Production / VPS: Doppler config `prd`
# DATABASE_URL=postgresql://talim:talim@db:5432/talim
# REDIS_URL=redis://redis:6379
# NEXT_PUBLIC_API_URL=https://talim-ai.uz/api
# CORS_ORIGIN=https://talim-ai.uz,https://admin.talim-ai.uz

# --- Cursor MCP / VPS SSH (dev config only; not used on server) ---
# Required in Doppler dev: TALIM_VPS_SSH_PASSWORD
# Optional overrides: TALIM_VPS_HOST (default 185.217.131.248), TALIM_VPS_USER (default root), TALIM_VPS_PORT (default 22)
# Set manually with: doppler secrets set TALIM_VPS_SSH_PASSWORD='...' --project talim-ai --config dev
