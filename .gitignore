!.env.example
doppler.json
*.log
uploads
.DS_Store
coverage
*.tsbuildinfo
.playwright-mcp/
# Ephemeral QA screenshots (repo root — delete after MCP/browser testing)
/*.png
# Generated QA test fixtures (regenerate: pnpm qa:fixtures — the script is the fixture)
docs/qa/fixtures/

# Graphify knowledge graph — commit the graph + Obsidian vault so they sync
# across machines via git. Ignore machine-specific + local-only bits.
# NOTE: git does not support inline (end-of-line) comments in .gitignore —
# the whole line is treated as the pattern, so comments must be on their own line.
# local-only cost data
graphify-out/cost.json
# large extraction cache
graphify-out/cache/
# machine-specific working files (interpreter path, scan root, labels)
graphify-out/.graphify_*
# dated graph backups written by `graphify update`
graphify-out/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]/
# per-user Obsidian app/session state (workspace layout, graph-view zoom) — noise
graphify-out/obsidian/.obsidian/

# Playwright e2e
apps/web/playwright-report/
apps/web/test-results/
apps/web/blob-report/
apps/web/.playwright/
