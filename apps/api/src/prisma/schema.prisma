generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum ContentType {
  PDF
  YOUTUBE
  SLIDE
}

enum ContentStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum MessageRole {
  USER
  ASSISTANT
}

enum PodcastStatus {
  PENDING
  GENERATING
  READY
  FAILED
}

enum QuizKind {
  FULL
  QUICK
}

enum GeneratedMediaStatus {
  PENDING
  GENERATING
  READY
  FAILED
}

enum TranscriptSource {
  YOUTUBE_CAPTIONS
  AI_TRANSCRIPTION
}

enum UserRole {
  INDIVIDUAL
  TENANT_OWNER
  TENANT_LEARNER
  ADMIN
}

enum UsageFeature {
  EMBED
  TUTOR_CHAT
  QUIZ_GEN
  PODCAST_GEN
  SECTION_GEN
  SUMMARY_GEN
  SLIDESHOW_GEN
  TRANSCRIBE
  PDF_PARSE
  TENANT_ASSISTANT
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  passwordHash            String
  name                    String?
  role                    UserRole                 @default(INDIVIDUAL)
  preferredLocale         String                   @default("uz")
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  contents                Content[]
  chatSessions            ChatSession[]
  quizzes                 Quiz[]
  quizAttempts            QuizAttempt[]
  contentProgress         ContentProgress[]
  sectionProgress         SectionProgress[]
  contentSummaries        ContentSummary[]
  podcastEpisodeProgress  PodcastEpisodeProgress[]
  learningActivityDays    LearningActivityDay[]
  apiUsageEvents          ApiUsageEvent[]
  adminAuditLogs          AdminAuditLog[]

  @@index([email])
  @@index([role])
}

model Content {
  id               String            @id @default(cuid())
  userId           String
  type             ContentType
  title            String
  url              String?
  storagePath      String?
  status           ContentStatus     @default(PENDING)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks           Chunk[]
  chatSessions     ChatSession[]
  quizzes          Quiz[]
  sections         ContentSection[]
  podcasts         Podcast[]
  contentVideos    ContentVideo[]
  transcriptSegments ContentTranscriptSegment[]
  contentProgress  ContentProgress[]
  contentSummaries ContentSummary[]

  @@index([userId])
  @@index([status])
}

model ContentSection {
  id              String                 @id @default(cuid())
  contentId       String
  title           String
  order           Int
  startChunk      Int
  endChunk        Int
  readMinutes     Int?
  content         Content                @relation(fields: [contentId], references: [id], onDelete: Cascade)
  quizzes         Quiz[]
  sectionProgress SectionProgress[]
  localizedTitles ContentSectionTitle[]

  @@index([contentId])
  @@index([contentId, order])
}

model ContentSectionTitle {
  id        String         @id @default(cuid())
  sectionId String
  locale    String
  title     String
  section   ContentSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, locale])
  @@index([sectionId])
}

model Podcast {
  id        String           @id @default(cuid())
  contentId String
  locale    String           @default("uz")
  status    PodcastStatus    @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  content   Content          @relation(fields: [contentId], references: [id], onDelete: Cascade)
  episodes  PodcastEpisode[]

  @@unique([contentId, locale])
  @@index([contentId])
}

model PodcastEpisode {
  id          String                   @id @default(cuid())
  podcastId   String
  title       String
  order       Int
  script      String
  audioPath   String?
  durationSec Int?
  sectionId   String?
  podcast     Podcast                  @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  progress    PodcastEpisodeProgress[]

  @@index([podcastId])
  @@index([podcastId, order])
}

model PodcastEpisodeProgress {
  id          String         @id @default(cuid())
  userId      String
  episodeId   String
  listenedSec Int            @default(0)
  completed   Boolean        @default(false)
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode     PodcastEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
  @@index([userId])
}

model Chunk {
  id         String                      @id @default(cuid())
  contentId  String
  text       String
  embedding  Unsupported("vector(1536)")?
  chunkIndex Int
  content    Content                     @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([chunkIndex])
}

model ContentTranscriptSegment {
  id        String           @id @default(cuid())
  contentId String
  order     Int
  startMs   Int
  endMs     Int
  text      String           @db.Text
  source    TranscriptSource
  createdAt DateTime         @default(now())
  content   Content          @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([contentId, order])
  @@index([contentId])
  @@index([contentId, startMs])
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  contentId String
  locale    String        @default("uz")
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content       @relation(fields: [contentId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@unique([userId, contentId, locale])
  @@index([userId])
  @@index([contentId])
}

model ChatMessage {
  id           String      @id @default(cuid())
  sessionId    String
  role         MessageRole
  text         String
  excerpt      String?     @db.Text
  excerptImage String?     @db.Text
  createdAt    DateTime    @default(now())
  session      ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Quiz {
  id        String         @id @default(cuid())
  contentId String
  userId    String
  sectionId String?
  kind      QuizKind       @default(FULL)
  locale    String         @default("uz")
  createdAt DateTime       @default(now())
  content   Content        @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  section   ContentSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([contentId])
  @@index([userId])
  @@index([contentId, userId, sectionId, kind, locale])
}

model QuizQuestion {
  id            String @id @default(cuid())
  quizId        String
  question      String
  options       Json
  correctAnswer String
  explanation   String?
  quiz          Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model QuizAttempt {
  id        String   @id @default(cuid())
  quizId    String
  userId    String
  score     Float
  answers   Json
  createdAt DateTime @default(now())
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@index([userId])
}

model ContentProgress {
  id               String   @id @default(cuid())
  userId           String
  contentId        String
  lastSectionId    String?
  overallCoverage  Float    @default(0)
  lastActivityAt   DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content          Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@index([userId])
}

model SectionProgress {
  id                 String         @id @default(cuid())
  userId             String
  sectionId          String
  contentId          String
  coverageScore      Float          @default(0)
  quizBestScore      Float?
  quickCheckAccuracy Float?
  viewedAt           DateTime?
  aiFeedback         String?
  updatedAt          DateTime       @updatedAt
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  section            ContentSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([userId, sectionId])
  @@index([userId])
  @@index([contentId])
}

model ContentSummary {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  scopeKey  String
  sectionId String?
  locale    String   @default("uz")
  summary   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId, scopeKey, locale])
  @@index([userId])
  @@index([contentId])
}

model ContentVideo {
  id          String               @id @default(cuid())
  contentId   String
  locale      String               @default("uz")
  scopeKey    String
  sectionId   String?
  status      GeneratedMediaStatus @default(PENDING)
  script      String?
  storagePath String?
  durationSec Int?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  content     Content              @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([contentId, locale, scopeKey])
  @@index([contentId])
}

model LearningActivityDay {
  id     String   @id @default(cuid())
  userId String
  date   DateTime @db.Date
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model ApiUsageEvent {
  id               String       @id @default(cuid())
  userId           String
  tenantId         String?
  feature          UsageFeature
  model            String
  inputTokens      Int          @default(0)
  outputTokens     Int          @default(0)
  estimatedCostUsd Decimal      @default(0) @db.Decimal(12, 6)
  metadata         Json?
  createdAt        DateTime     @default(now())
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([tenantId, createdAt])
  @@index([feature, createdAt])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String
  action      String
  targetType  String
  targetId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  adminUser   User     @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, createdAt])
  @@index([targetType, targetId])
}
