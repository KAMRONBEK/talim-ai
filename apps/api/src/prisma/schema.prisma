generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum ContentType {
  PDF
  YOUTUBE
  SLIDE
}

enum ContentStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum MessageRole {
  USER
  ASSISTANT
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  name         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  contents     Content[]
  chatSessions ChatSession[]
  quizzes      Quiz[]
  quizAttempts QuizAttempt[]

  @@index([email])
}

model Content {
  id          String        @id @default(cuid())
  userId      String
  type        ContentType
  title       String
  url         String?
  storagePath String?
  status      ContentStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks      Chunk[]
  chatSessions ChatSession[]
  quizzes     Quiz[]

  @@index([userId])
  @@index([status])
}

model Chunk {
  id         String                      @id @default(cuid())
  contentId  String
  text       String
  embedding  Unsupported("vector(1536)")?
  chunkIndex Int
  content    Content                     @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([chunkIndex])
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  contentId String
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content       @relation(fields: [contentId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([userId])
  @@index([contentId])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      MessageRole
  text      String
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Quiz {
  id        String         @id @default(cuid())
  contentId String
  userId    String
  createdAt DateTime       @default(now())
  content   Content        @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([contentId])
  @@index([userId])
}

model QuizQuestion {
  id            String @id @default(cuid())
  quizId        String
  question      String
  options       Json
  correctAnswer String
  explanation   String?
  quiz          Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model QuizAttempt {
  id        String   @id @default(cuid())
  quizId    String
  userId    String
  score     Float
  answers   Json
  createdAt DateTime @default(now())
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@index([userId])
}
