generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum ContentType {
  PDF
  YOUTUBE
  SLIDE
}

enum ContentStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum MessageRole {
  USER
  ASSISTANT
}

enum PodcastStatus {
  PENDING
  GENERATING
  READY
  FAILED
}

enum QuizKind {
  FULL
  QUICK
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  passwordHash            String
  name                    String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  contents                Content[]
  chatSessions            ChatSession[]
  quizzes                 Quiz[]
  quizAttempts            QuizAttempt[]
  contentProgress         ContentProgress[]
  sectionProgress         SectionProgress[]
  contentSummaries        ContentSummary[]
  podcastEpisodeProgress  PodcastEpisodeProgress[]
  learningActivityDays    LearningActivityDay[]

  @@index([email])
}

model Content {
  id               String            @id @default(cuid())
  userId           String
  type             ContentType
  title            String
  url              String?
  storagePath      String?
  status           ContentStatus     @default(PENDING)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks           Chunk[]
  chatSessions     ChatSession[]
  quizzes          Quiz[]
  sections         ContentSection[]
  podcast          Podcast?
  contentProgress  ContentProgress[]
  contentSummaries ContentSummary[]

  @@index([userId])
  @@index([status])
}

model ContentSection {
  id              String            @id @default(cuid())
  contentId       String
  title           String
  order           Int
  startChunk      Int
  endChunk        Int
  readMinutes     Int?
  content         Content           @relation(fields: [contentId], references: [id], onDelete: Cascade)
  quizzes         Quiz[]
  sectionProgress SectionProgress[]

  @@index([contentId])
  @@index([contentId, order])
}

model Podcast {
  id        String           @id @default(cuid())
  contentId String           @unique
  status    PodcastStatus    @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  content   Content          @relation(fields: [contentId], references: [id], onDelete: Cascade)
  episodes  PodcastEpisode[]

  @@index([contentId])
}

model PodcastEpisode {
  id          String                   @id @default(cuid())
  podcastId   String
  title       String
  order       Int
  script      String
  audioPath   String?
  durationSec Int?
  sectionId   String?
  podcast     Podcast                  @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  progress    PodcastEpisodeProgress[]

  @@index([podcastId])
  @@index([podcastId, order])
}

model PodcastEpisodeProgress {
  id          String         @id @default(cuid())
  userId      String
  episodeId   String
  listenedSec Int            @default(0)
  completed   Boolean        @default(false)
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode     PodcastEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
  @@index([userId])
}

model Chunk {
  id         String                      @id @default(cuid())
  contentId  String
  text       String
  embedding  Unsupported("vector(1536)")?
  chunkIndex Int
  content    Content                     @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([chunkIndex])
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  contentId String
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content       @relation(fields: [contentId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([userId])
  @@index([contentId])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      MessageRole
  text      String
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Quiz {
  id        String         @id @default(cuid())
  contentId String
  userId    String
  sectionId String?
  kind      QuizKind       @default(FULL)
  createdAt DateTime       @default(now())
  content   Content        @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  section   ContentSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([contentId])
  @@index([userId])
  @@index([contentId, userId, sectionId, kind])
}

model QuizQuestion {
  id            String @id @default(cuid())
  quizId        String
  question      String
  options       Json
  correctAnswer String
  explanation   String?
  quiz          Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model QuizAttempt {
  id        String   @id @default(cuid())
  quizId    String
  userId    String
  score     Float
  answers   Json
  createdAt DateTime @default(now())
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@index([userId])
}

model ContentProgress {
  id               String   @id @default(cuid())
  userId           String
  contentId        String
  lastSectionId    String?
  overallCoverage  Float    @default(0)
  lastActivityAt   DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content          Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@index([userId])
}

model SectionProgress {
  id                 String         @id @default(cuid())
  userId             String
  sectionId          String
  contentId          String
  coverageScore      Float          @default(0)
  quizBestScore      Float?
  quickCheckAccuracy Float?
  viewedAt           DateTime?
  aiFeedback         String?
  updatedAt          DateTime       @updatedAt
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  section            ContentSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([userId, sectionId])
  @@index([userId])
  @@index([contentId])
}

model ContentSummary {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  scopeKey  String
  sectionId String?
  summary   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId, scopeKey])
  @@index([userId])
  @@index([contentId])
}

model LearningActivityDay {
  id     String   @id @default(cuid())
  userId String
  date   DateTime @db.Date
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}
