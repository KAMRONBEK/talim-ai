generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum ContentType {
  PDF
  YOUTUBE
  SLIDE
}

enum ContentStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum MessageRole {
  USER
  ASSISTANT
}

enum PodcastStatus {
  PENDING
  GENERATING
  READY
  FAILED
}

enum QuizKind {
  FULL
  QUICK
}

enum GeneratedMediaStatus {
  PENDING
  GENERATING
  READY
  FAILED
}

enum TranscriptSource {
  YOUTUBE_CAPTIONS
  AI_TRANSCRIPTION
}

enum UserRole {
  INDIVIDUAL
  TENANT_OWNER
  TENANT_LEARNER
  ADMIN
}

enum UsageFeature {
  EMBED
  TUTOR_CHAT
  QUIZ_GEN
  QUESTION_DRAFT
  PODCAST_GEN
  SECTION_GEN
  SUMMARY_GEN
  SLIDESHOW_GEN
  VIDEO_GEN
  TRANSCRIBE
  PDF_PARSE
  TENANT_ASSISTANT
}

enum PlanKind {
  INDIVIDUAL
  TENANT
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum SubscriptionSource {
  ADMIN
  PAYMENT_PROVIDER
}

enum TenantMemberRole {
  OWNER
  LEARNER
}

enum QuestionType {
  SHORT_ANSWER
  NUMERIC
  MULTIPLE_CHOICE
  TRUE_FALSE
  MULTIPLE_SELECT
  FILL_BLANK
  DROPDOWN_CLOZE
  MATCHING
  ORDERING
  HOTSPOT
  DRAG_DROP
}

enum BankQuestionStatus {
  DRAFT
  APPROVED
  REJECTED
}

enum TenantAssessmentStatus {
  DRAFT
  PUBLISHED
}

enum AssessmentAttemptStatus {
  SUBMITTED
  GRADED
}

enum TutorRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AssessmentMode {
  WRITTEN
  GAME
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  username                String?                  @unique
  passwordHash            String
  adminPasswordNote       String?
  mustChangePassword      Boolean                  @default(false)
  name                    String?
  role                    UserRole                 @default(INDIVIDUAL)
  preferredLocale         String                   @default("uz")
  stripeCustomerId        String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  contents                Content[]
  chatSessions            ChatSession[]
  quizzes                 Quiz[]
  quizAttempts            QuizAttempt[]
  contentProgress         ContentProgress[]
  sectionProgress         SectionProgress[]
  contentSummaries        ContentSummary[]
  podcastEpisodeProgress  PodcastEpisodeProgress[]
  learningActivityDays    LearningActivityDay[]
  apiUsageEvents          ApiUsageEvent[]
  adminAuditLogs          AdminAuditLog[]
  subscription            Subscription?
  ownedTenants            Tenant[]                 @relation("OwnedTenants")
  tenantMemberships       TenantMembership[]
  assignmentsMade         ContentAssignment[]      @relation("AssignmentsMade")
  contentAssignments      ContentAssignment[]      @relation("LearnerAssignments")
  questionBanksCreated    QuestionBank[]           @relation("QuestionBanksCreated")
  bankQuestionsCreated    BankQuestion[]           @relation("BankQuestionsCreated")
  assessmentsCreated      TenantAssessment[]       @relation("AssessmentsCreated")
  assessmentAssignments   AssessmentAssignment[]   @relation("AssessmentAssignmentsMade")
  assignedAssessments     AssessmentAssignment[]   @relation("AssessmentLearnerAssignments")
  assessmentAttempts      AssessmentAttempt[]
  tutorRequests           TutorRequest[]           @relation("TutorRequests")
  sectionMasteries        SectionMastery[]

  @@index([email])
  @@index([role])
}

model TutorRequest {
  id          String             @id @default(cuid())
  userId      String
  orgName     String
  note        String?
  status      TutorRequestStatus @default(PENDING)
  decidedById String?
  decidedAt   DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation("TutorRequests", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Tenant {
  id               String             @id @default(cuid())
  name             String
  slug             String             @unique
  joinCode         String?            @unique
  seatLimit        Int?
  ownerId          String
  stripeCustomerId String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  owner            User               @relation("OwnedTenants", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships      TenantMembership[]
  contents         Content[]
  subscription     Subscription?
  questionBanks    QuestionBank[]
  assessments      TenantAssessment[]

  @@index([ownerId])
}

model TenantMembership {
  id        String           @id @default(cuid())
  tenantId  String
  userId    String
  role      TenantMemberRole
  active    Boolean          @default(true)
  joinedAt  DateTime         @default(now())
  tutorNote String?
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

// One-way tutor→student message (Wave 3 area D). Plain ids (no User/Tenant relations)
// to stay additive; delivery/read state lives on TenantMessageRecipient.
model TenantMessage {
  id         String                   @id @default(cuid())
  tenantId   String
  senderId   String
  threadId   String?
  body       String                   @db.Text
  createdAt  DateTime                 @default(now())
  recipients TenantMessageRecipient[]

  @@index([tenantId])
  @@index([senderId])
  @@index([threadId])
}

model TenantMessageRecipient {
  id          String        @id @default(cuid())
  messageId   String
  recipientId String
  readAt      DateTime?
  message     TenantMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, recipientId])
  @@index([recipientId])
}

model ContentAssignment {
  id           String   @id @default(cuid())
  contentId    String
  learnerId    String
  assignedById String
  assignedAt   DateTime @default(now())
  content      Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  learner      User     @relation("LearnerAssignments", fields: [learnerId], references: [id], onDelete: Cascade)
  assignedBy   User     @relation("AssignmentsMade", fields: [assignedById], references: [id], onDelete: Cascade)

  @@unique([contentId, learnerId])
  @@index([learnerId])
  @@index([contentId])
}

model Content {
  id               String            @id @default(cuid())
  userId           String
  tenantId         String?
  type             ContentType
  title            String
  url              String?
  storagePath      String?
  status           ContentStatus     @default(PENDING)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant           Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chunks           Chunk[]
  chatSessions     ChatSession[]
  quizzes          Quiz[]
  sections         ContentSection[]
  podcasts         Podcast[]
  contentVideos    ContentVideo[]
  flashcardDecks   FlashcardDeck[]
  slideDecks       ContentSlideDeck[]
  transcriptSegments ContentTranscriptSegment[]
  contentProgress  ContentProgress[]
  contentSummaries ContentSummary[]
  assignments      ContentAssignment[]
  bankQuestions    BankQuestion[]
  bankLinks        QuestionBankContent[]
  assessmentAssignments AssessmentAssignment[]
  figures          ContentFigure[]
  sectionMasteries SectionMastery[]

  @@index([userId])
  @@index([tenantId])
  @@index([status])
}

model ContentSection {
  id              String                 @id @default(cuid())
  contentId       String
  parentId        String?
  depth           Int                    @default(0)
  title           String
  order           Int
  startChunk      Int
  endChunk        Int
  readMinutes     Int?
  content         Content                @relation(fields: [contentId], references: [id], onDelete: Cascade)
  parent          ContentSection?        @relation("SectionHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children        ContentSection[]       @relation("SectionHierarchy")
  quizzes         Quiz[]
  sectionProgress SectionProgress[]
  localizedTitles ContentSectionTitle[]
  bankQuestions   BankQuestion[]
  assessmentAssignments AssessmentAssignment[]

  @@index([contentId])
  @@index([contentId, order])
  @@index([parentId])
}

model ContentSectionTitle {
  id        String         @id @default(cuid())
  sectionId String
  locale    String
  title     String
  section   ContentSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, locale])
  @@index([sectionId])
}

model Podcast {
  id        String           @id @default(cuid())
  contentId String
  locale    String           @default("uz")
  status    PodcastStatus    @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  content   Content          @relation(fields: [contentId], references: [id], onDelete: Cascade)
  episodes  PodcastEpisode[]

  @@unique([contentId, locale])
  @@index([contentId])
}

model PodcastEpisode {
  id          String                   @id @default(cuid())
  podcastId   String
  title       String
  order       Int
  script      String
  audioPath   String?
  durationSec Int?
  sectionId   String?
  // Real per-turn transcript timings [{ speaker, text, startMs, endMs }] captured at
  // synthesis from each dialogue turn's audio byte length (CBR mp3 ⇒ bytes ≈ ms).
  // Null on legacy episodes → the client falls back to char-proportion estimation.
  segments    Json?
  podcast     Podcast                  @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  progress    PodcastEpisodeProgress[]

  @@index([podcastId])
  @@index([podcastId, order])
}

model PodcastEpisodeProgress {
  id          String         @id @default(cuid())
  userId      String
  episodeId   String
  listenedSec Int            @default(0)
  completed   Boolean        @default(false)
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode     PodcastEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
  @@index([userId])
}

model Chunk {
  id         String                      @id @default(cuid())
  contentId  String
  text       String
  embedding  Unsupported("vector(1536)")?
  chunkIndex Int
  content    Content                     @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([chunkIndex])
}

// A figure/diagram/chart/table extracted from the source, described by a vision
// model. The caption is embedded so figures are retrievable alongside text chunks,
// and storagePath (when present) lets generated content re-surface the actual image.
model ContentFigure {
  id          String                      @id @default(cuid())
  contentId   String
  page        Int?
  caption     String
  storagePath String?
  embedding   Unsupported("vector(1536)")?
  createdAt   DateTime                    @default(now())
  content     Content                     @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
}

model ContentTranscriptSegment {
  id        String           @id @default(cuid())
  contentId String
  order     Int
  startMs   Int
  endMs     Int
  text      String           @db.Text
  source    TranscriptSource
  createdAt DateTime         @default(now())
  content   Content          @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([contentId, order])
  @@index([contentId])
  @@index([contentId, startMs])
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  contentId String
  locale    String        @default("uz")
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content       @relation(fields: [contentId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@unique([userId, contentId, locale])
  @@index([userId])
  @@index([contentId])
}

model ChatMessage {
  id           String      @id @default(cuid())
  sessionId    String
  role         MessageRole
  text         String
  excerpt      String?     @db.Text
  excerptImage String?     @db.Text
  createdAt    DateTime    @default(now())
  session      ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Quiz {
  id        String         @id @default(cuid())
  contentId String
  userId    String
  sectionId String?
  kind      QuizKind       @default(FULL)
  // Generation style chosen by the learner (mixed | multipleChoice | trueFalse |
  // written | numeric). Mirrors the tutor question-bank styles so individuals get
  // the same range of question types. Kept as a string (not a Prisma enum) to match
  // the zod questionStyleEnum without a migration whenever a style is added.
  style     String         @default("mixed")
  // Requested question count; null means "derive from kind" (QUICK=2, FULL=5).
  count     Int?
  // Requested cognitive depth (recall | understanding | application | mixed).
  depth     String         @default("mixed")
  // Requested question types (JSON array of QuestionType). Null = derive from legacy style.
  types     Json?
  locale    String         @default("uz")
  createdAt DateTime       @default(now())
  content   Content        @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  section   ContentSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([contentId])
  @@index([userId])
  @@index([contentId, userId, sectionId, kind, locale, style])
}

model QuizQuestion {
  id            String       @id @default(cuid())
  quizId        String
  question      String
  type          QuestionType @default(MULTIPLE_CHOICE)
  // Options are only present for MULTIPLE_CHOICE; null for SHORT_ANSWER / NUMERIC.
  options       Json?
  // Legacy single-answer field, still populated (with acceptableAnswers[0]) for
  // backward compatibility and multiple-choice grading.
  correctAnswer String
  // Accepted answers for grading all question types. Null on pre-migration rows
  // (those are multiple-choice and fall back to correctAnswer).
  acceptableAnswers Json?
  // Per-type structured config (FILL_BLANK blanks, MATCHING pairs, ORDERING items, ...).
  config        Json?
  explanation   String?
  // LLM-declared difficulty (easy | medium | hard); seeds the mastery item prior.
  difficulty    String?
  // Cognitive depth this item targets (recall | understanding | application).
  bloom         String?
  // Verbatim span from the source material proving the correct answer (hallucination firewall).
  sourceQuote   String?      @db.Text
  // Misconception rationales aligned with options order (JSON array of string|null).
  optionRationales Json?
  // Section the item was sourced from — resolved from chunk provenance for full-content quizzes.
  sourceSectionId  String?
  quiz          Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model QuizAttempt {
  id        String   @id @default(cuid())
  quizId    String
  userId    String
  score     Float
  answers   Json
  createdAt DateTime @default(now())
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@index([userId])
}

// AI-generated flashcard deck for a content (optionally scoped to a section + locale),
// mirroring the ContentVideo per-scope pattern. Cards are simple front/back pairs studied
// with a flip + again/good UI.
model FlashcardDeck {
  id        String               @id @default(cuid())
  contentId String
  locale    String               @default("uz")
  scopeKey  String
  sectionId String?
  status    GeneratedMediaStatus @default(PENDING)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  content   Content              @relation(fields: [contentId], references: [id], onDelete: Cascade)
  cards     Flashcard[]

  @@unique([contentId, locale, scopeKey])
  @@index([contentId])
}

model Flashcard {
  id        String        @id @default(cuid())
  deckId    String
  front     String        @db.Text
  back      String        @db.Text
  order     Int           @default(0)
  createdAt DateTime      @default(now())
  deck      FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  reviews   FlashcardReview[]

  @@index([deckId])
}

// Per-user spaced-repetition state for a flashcard (SM-2). userId is a plain id (no User
// back-relation) to stay additive; state cascades when the card is deleted.
model FlashcardReview {
  id             String    @id @default(cuid())
  userId         String
  flashcardId    String
  easeFactor     Float     @default(2.5)
  intervalDays   Int       @default(0)
  repetitions    Int       @default(0)
  lastReviewedAt DateTime?
  nextReviewAt   DateTime?
  flashcard      Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([userId, flashcardId])
  @@index([userId, nextReviewAt])
}

model QuestionBank {
  id          String         @id @default(cuid())
  tenantId    String
  title       String
  topic       String?
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy   User           @relation("QuestionBanksCreated", fields: [createdById], references: [id], onDelete: Cascade)
  questions   BankQuestion[]
  materials   QuestionBankContent[]
  assessments TenantAssessment[]

  @@index([tenantId])
  @@index([createdById])
}

// Join: a question bank is "about" one or more materials (Content). Generated questions can
// then be sourced from the bank's linked materials. Tenant isolation is enforced at the API
// layer (both bank and content belong to the same tenant).
model QuestionBankContent {
  bankId    String
  contentId String
  createdAt DateTime     @default(now())
  bank      QuestionBank @relation(fields: [bankId], references: [id], onDelete: Cascade)
  content   Content      @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@id([bankId, contentId])
  @@index([contentId])
}

model BankQuestion {
  id                String             @id @default(cuid())
  bankId            String
  createdById       String
  sourceContentId   String?
  sourceSectionId   String?
  type              QuestionType       @default(SHORT_ANSWER)
  prompt            String             @db.Text
  options           Json?
  acceptableAnswers Json
  config            Json?
  explanation       String?            @db.Text
  // LLM-declared difficulty (easy | medium | hard); seeds the mastery item prior.
  difficulty        String?
  // Cognitive depth this item targets (recall | understanding | application).
  bloom             String?
  // Verbatim span from the source material proving the correct answer (hallucination firewall).
  sourceQuote       String?            @db.Text
  // Misconception rationales aligned with options order (JSON array of string|null).
  optionRationales  Json?
  status            BankQuestionStatus @default(DRAFT)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  bank              QuestionBank       @relation(fields: [bankId], references: [id], onDelete: Cascade)
  createdBy         User               @relation("BankQuestionsCreated", fields: [createdById], references: [id], onDelete: Cascade)
  sourceContent     Content?           @relation(fields: [sourceContentId], references: [id], onDelete: SetNull)
  sourceSection     ContentSection?    @relation(fields: [sourceSectionId], references: [id], onDelete: SetNull)
  assessmentLinks   AssessmentQuestion[]

  @@index([bankId])
  @@index([createdById])
  @@index([sourceContentId])
  @@index([sourceSectionId])
  @@index([status])
}

model TenantAssessment {
  id           String                 @id @default(cuid())
  tenantId     String
  bankId       String?
  title        String
  instructions String?
  maxAttempts  Int                    @default(1)
  mode         AssessmentMode         @default(WRITTEN)
  secondsPerQuestion Int?
  status       TenantAssessmentStatus @default(DRAFT)
  strictScoring Boolean               @default(false)
  wrongPenalty  Float                 @default(0.5)
  partialCredit Boolean               @default(true)
  scheduledAt  DateTime?
  isLive       Boolean                @default(false)
  liveEndsAt   DateTime?
  createdById  String
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bank         QuestionBank?          @relation(fields: [bankId], references: [id], onDelete: SetNull)
  createdBy    User                   @relation("AssessmentsCreated", fields: [createdById], references: [id], onDelete: Cascade)
  questions    AssessmentQuestion[]
  assignments  AssessmentAssignment[]
  attempts     AssessmentAttempt[]

  @@index([tenantId])
  @@index([bankId])
  @@index([createdById])
  @@index([status])
}

model AssessmentQuestion {
  id           String           @id @default(cuid())
  assessmentId String
  questionId   String
  order        Int
  points       Float            @default(1)
  assessment   TenantAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question     BankQuestion     @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, questionId])
  @@index([assessmentId])
  @@index([questionId])
}

model AssessmentAssignment {
  id           String           @id @default(cuid())
  assessmentId String
  learnerId    String?
  contentId    String?
  sectionId    String?
  assignedById String
  assignedAt   DateTime         @default(now())
  dueAt        DateTime?
  assessment   TenantAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  learner      User?            @relation("AssessmentLearnerAssignments", fields: [learnerId], references: [id], onDelete: Cascade)
  content      Content?         @relation(fields: [contentId], references: [id], onDelete: Cascade)
  section      ContentSection?  @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  assignedBy   User             @relation("AssessmentAssignmentsMade", fields: [assignedById], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([learnerId])
  @@index([contentId])
  @@index([sectionId])
  @@index([assignedById])
}

model AssessmentAttempt {
  id           String                  @id @default(cuid())
  assessmentId String
  userId       String
  answers      Json
  score        Float?
  pointsTotal  Int                     @default(0)
  pointsEarned Float?
  maxPoints    Float?
  maxStreak    Int                     @default(0)
  durationMs   Int?
  status       AssessmentAttemptStatus @default(SUBMITTED)
  submittedAt  DateTime                @default(now())
  createdAt    DateTime                @default(now())
  assessment   TenantAssessment        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  answerDetails AttemptAnswer[]

  @@index([assessmentId])
  @@index([userId])
  @@index([assessmentId, pointsTotal])
}

model AttemptAnswer {
  id            String            @id @default(cuid())
  attemptId     String
  questionId    String
  answer         String
  correct        Boolean
  responseMs     Int?
  pointsAwarded  Int               @default(0)
  pointsEarned   Float?
  creditFraction Float?
  attempt       AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([attemptId])
}

enum MediaReviewStatus {
  PENDING
  APPROVED
  FLAGGED
}

// Polymorphic admin review of generated media (podcast/quiz/video/summary), keyed by
// (kind, mediaId) so one table backs approve/flag across all generated-media types.
model GeneratedMediaReview {
  id           String            @id @default(cuid())
  kind         String
  mediaId      String
  status       MediaReviewStatus @default(PENDING)
  reviewedById String?
  note         String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([kind, mediaId])
  @@index([status])
}

model ContentProgress {
  id               String   @id @default(cuid())
  userId           String
  contentId        String
  lastSectionId    String?
  overallCoverage  Float    @default(0)
  lastActivityAt   DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content          Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@index([userId])
}

model SectionProgress {
  id                 String         @id @default(cuid())
  userId             String
  sectionId          String
  contentId          String
  coverageScore      Float          @default(0)
  quizBestScore      Float?
  quickCheckAccuracy Float?
  viewedAt           DateTime?
  aiFeedback         String?
  updatedAt          DateTime       @updatedAt
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  section            ContentSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([userId, sectionId])
  @@index([userId])
  @@index([contentId])
}

// Per-(user, content, section) mastery state for the unified question engine — Elo-KT.
// theta is an ability logit (clamped ±3); displayed mastery = 100·sigmoid(theta) with
// Khan-style bands gated by attempt counts + distinct active days. scopeKey mirrors the
// FlashcardDeck pattern ('full' when sectionId is null) so the unique key holds for the
// whole-material bucket. Correct answers raise theta, wrong answers lower it; inactivity
// decays it lazily at read/update time (no cron).
model SectionMastery {
  id            String    @id @default(cuid())
  userId        String
  contentId     String
  sectionId     String?
  scopeKey      String
  theta         Float     @default(0)
  attempts      Int       @default(0)
  correct       Int       @default(0)
  // Distinct calendar days with at least one answer (gates the "mastered" band).
  activeDays    Int       @default(0)
  lastAnswerDay String?
  lastAnswerAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  content       Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId, scopeKey])
  @@index([userId])
  @@index([contentId])
}

// Online difficulty calibration for question items across all users. itemKey is
// "quiz:<quizQuestionId>" | "bank:<bankQuestionId>" | "card:<flashcardId>" (no FK on
// purpose — items live in three tables). difficulty is an Elo logit seeded from the
// LLM-declared difficulty (easy/medium/hard → −1/0/+1) with a pseudo-count prior.
model QuestionStat {
  itemKey    String   @id
  difficulty Float    @default(0)
  attempts   Int      @default(0)
  updatedAt  DateTime @updatedAt
}

model ContentSummary {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  scopeKey  String
  sectionId String?
  locale    String   @default("uz")
  summary   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId, scopeKey, locale])
  @@index([userId])
  @@index([contentId])
}

model ContentVideo {
  id          String               @id @default(cuid())
  contentId   String
  locale      String               @default("uz")
  scopeKey    String
  sectionId   String?
  status      GeneratedMediaStatus @default(PENDING)
  script      String?
  storagePath String?
  durationSec Int?
  // Per-slide narration timeline: [{ index, title, narration, audioPath, durationSec }].
  // The "video" is rendered in-browser as a narrated slideshow (deck slides synced
  // to these per-slide TTS clips), so there is no single encoded file.
  segments    Json?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  content     Content              @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([contentId, locale, scopeKey])
  @@index([contentId])
}

model ContentSlideDeck {
  id          String               @id @default(cuid())
  contentId   String
  locale      String               @default("uz")
  scopeKey    String
  sectionId   String?
  status      GeneratedMediaStatus @default(PENDING)
  audience    String               @default("students")
  accent      String               @default("teal")
  deck        Json?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  content     Content              @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([contentId, locale, scopeKey])
  @@index([contentId])
}

model LearningActivityDay {
  id     String   @id @default(cuid())
  userId String
  date   DateTime @db.Date
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model ApiUsageEvent {
  id               String       @id @default(cuid())
  userId           String
  tenantId         String?
  feature          UsageFeature
  model            String
  inputTokens      Int          @default(0)
  outputTokens     Int          @default(0)
  estimatedCostUsd Decimal      @default(0) @db.Decimal(12, 6)
  metadata         Json?
  createdAt        DateTime     @default(now())
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([tenantId, createdAt])
  @@index([feature, createdAt])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  // Nullable + SetNull so deleting an admin never erases the audit trail. The
  // actor's identity is snapshotted into adminEmail/adminName at write time so the
  // log stays readable even after the user row is gone.
  adminUserId String?
  adminEmail  String?
  adminName   String?
  action      String
  targetType  String
  targetId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  adminUser   User?    @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId, createdAt])
  @@index([targetType, targetId])
}

model Plan {
  id            String         @id @default(cuid())
  code          String         @unique
  name          String
  kind          PlanKind
  limits        Json
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String?            @unique
  tenantId               String?            @unique
  planId                 String
  status                 SubscriptionStatus @default(ACTIVE)
  source                 SubscriptionSource @default(ADMIN)
  externalSubscriptionId String?            @unique
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  user                   User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant                 Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan                   Plan               @relation(fields: [planId], references: [id])

  @@index([planId])
  @@index([status])
}
