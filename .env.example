# Secrets are managed in Doppler — do not commit .env files.
#
# Setup:
#   1. Install CLI: https://docs.doppler.com/docs/install-cli
#   2. doppler login
#   3. pnpm doppler:setup          # links repo to project talim-ai / config dev
#   4. pnpm doppler:upload         # one-time import from env.template (optional)
#   5. pnpm dev:infra && pnpm dev  # starts db/redis + apps with injected secrets
#
# See env.template for all variable names.
#
# Docker without Doppler:
#   cp env.template .env
#   # Edit JWT_SECRET (must be at least 32 characters)
#   docker compose up -d --build
#
# Docker with Doppler (recommended):
#   pnpm docker:up
